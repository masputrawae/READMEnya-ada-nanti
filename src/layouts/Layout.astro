---
import '../styles/global.css'
import Footer from './Footer.astro'

import Headed from "./Headed.astro"
import Header from './Header.astro'
import Sidebar from './Sidebar.astro'

const { href, activeLink } = Astro.props
---

<html lang="id" class="bg-zinc-900 text-zinc-300 text-[14px] font-sans">
	<head>
		<Headed />
	</head>
	<body>
    <Sidebar />
    <div>
      <Header href={href} activeLink={activeLink} />
      <slot />
      <Footer />
    </div>
	</body>
</html>
