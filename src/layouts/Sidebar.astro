---
import { Icon } from 'astro-icon/components'
import Brand from '../components/Brand.astro'
import Navigation from '../components/Navigation.astro'
---

<aside
  id="sidebar"
	class="z-50 sidebar fixed top-0 left-0 flex flex-col gap-5 h-dvh w-xs  overflow-y-auto transition-all duration-500 border-r border-r-zinc-800 bg-zinc-900 p-5 lg:sticky lg:visible lg:translate-none lg:w-full lg:max-w-full lg:border-none" 
>
	<Brand sidebar="close" />
	<Navigation />
</aside>
<style>
  @reference '../styles/global.css';

  @layer components {
    .sidebar {
      @apply -translate-x-full invisible 
    }

    .sidebar.isActive {
      @apply visible -translate-x-0
    }
  }
</style>