---
import { SITE_DEFAULT } from '../site.config'

const title = SITE_DEFAULT.title
const year = new Date().getFullYear()
---

<footer
	class="m-auto mt-10 flex w-full flex-col items-center border-t border-t-neutral-700 px-5 py-5 text-xs md:flex-row md:justify-between lg:px-10"
>
	<p>
		© {year} · {title} · All rights reserved. | <a
			class="text-blue-400 hover:text-blue-200"
			href="/disclaimer/">Disclaimer</a
		>
	</p>
	<p>
		Made with ❤️ using <a
			class="text-blue-400 hover:text-blue-200"
			href="https://astro.build/"
			target="_blank"
			rel="noopener noreferrer">{Astro.generator}</a
		>
	</p>
</footer>
