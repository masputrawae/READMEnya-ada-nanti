---
import { SiteConfig, MENUS } from '../siteConfig'
import Prose from './Prose.astro'
import { Icon } from 'astro-icon/components'

const socialMedia = MENUS.social
const footerNav = MENUS.footer
---

<div class="mt-28 border-t-2 border-neutral-800 px-3.5 py-5 shadow-md shadow-black">
	<footer class="mx-auto max-w-5xl">
		<nav class="mb-10 flex items-center justify-center gap-5">
			{
				socialMedia.map((i) => (
					<a
						href={i.url}
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm hover:text-amber-500"
					>
						<Icon name={i.icon} class="size-10" aria-label={i.label} role="img" title={i.label} />
					</a>
				))
			}
		</nav>

		<div class="text-center">
			<p>
				© {new Date().getFullYear()} · <strong>Putra Jaya</strong> · All rights reserved.
			</p>

			<p>
				Generate Using <a href="https://astro.build/" class="text-blue-500 underline"
					>{Astro.generator}</a
				>
			</p>
		</div>
	</footer>
</div>
