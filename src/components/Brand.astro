---
import { SiteConfig } from '../siteConfig'
import { Image } from 'astro:assets'
---

<figure class="flex items-center gap-1.5">
	<Image
		src={SiteConfig.logo}
		alt={SiteConfig.author}
		format="svg"
		width={48}
		height={48}
		densities={[1.5, 2]}
		loading="eager"
		class="rounded-full shadow-sm shadow-black/80"
	/>
	<figcaption class="font-light text-shadow-black text-shadow-sm">
		<strong class="block text-xl text-neutral-50">{SiteConfig.author}</strong>
		<em class="block text-sm text-neutral-400 not-italic">{SiteConfig.tagline}</em>
	</figcaption>
</figure>
