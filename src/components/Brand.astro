---
import { SiteConfig } from '../siteConfig'
import { Image } from 'astro:assets'
---

<figure class="flex cursor-pointer items-center gap-3" onclick="window.location.href='/'">
	<picture class="overflow-hidden rounded-full shadow-md">
		<Image
			src={SiteConfig.logo}
			alt={SiteConfig.author}
			width={50}
			height={50}
			class="lg:size-16"
			loading="eager"
		/>
	</picture>
	<figcaption class="flex flex-col">
		<strong class="text-xl font-semibold text-white text-shadow-black text-shadow-sm lg:text-2xl"
			>{SiteConfig.author}</strong
		>
		<em class="text-sm text-neutral-300 not-italic text-shadow-black text-shadow-sm lg:text-base"
			>{SiteConfig.tagline}</em
		>
	</figcaption>
</figure>
