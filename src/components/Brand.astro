---
// src > components > Brand.astro
import { DEFAULT_PARAMS } from "../siteConfig";
const author = DEFAULT_PARAMS.owner
---

<figure>
  <picture>
    <img src={author.logo} alt={author.name}>
  </picture>

  <figcaption>
    <strong>{author.name}</strong>
    <em>{author.tagline}</em>
  </figcaption>
</figure>