---
import { AUTHOR } from '../data/site'
---

<figure
  class="flex items-center gap-2 cursor-pointer"
  onclick='window.location.href="/"'
>
  <picture
    class="size-12 rounded-full overflow-hidden border-2 border-neutral-700 shadow-sm shadow-black transition-shadow hover:shadow-md"
  >
    <img
      src={AUTHOR.logo}
      alt={`Logo ${AUTHOR.name}`}
      class="size-full transition-transform hover:scale-120"
    />
  </picture>

  <figcaption class="flex flex-col leading-5">
    <strong class="text-white text-shadow-md text-shadow-black"
      >{AUTHOR.name}</strong
    >
    <em
      class="not-italic text-neutral-400 text-xs text-shadow-sm text-shadow-black"
      >{AUTHOR.tagline}</em
    >
  </figcaption>
</figure>
