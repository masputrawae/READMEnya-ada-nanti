---
import { Image } from 'astro:assets'
import { siteConfig } from '../siteConfig'
---

<figure class="flex cursor-pointer items-center gap-2.5" onclick='window.location.href="/"'>
	<Image
		src={siteConfig.logo}
		alt={`Logo ${siteConfig.title}`}
		width={48}
		height={48}
		format="webp"
		loading="eager"
		densities={[1.5, 2]}
		class="rounded-full shadow-sm shadow-black/50"
	/>
	<figcaption class="leading-6">
		<strong class="block text-lg font-semibold text-neutral-50 text-shadow-black/80 text-shadow-md">
			{siteConfig.author}
		</strong>
		<em class="block text-xs text-neutral-400 not-italic text-shadow-black text-shadow-sm">
			{siteConfig.tagline}
		</em>
	</figcaption>
</figure>
