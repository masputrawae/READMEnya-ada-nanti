---
import { Icon } from 'astro-icon/components'

const { item } = Astro.props
---

<div class="flex flex-col py-5">
	{
		item.map((i) => {
			// IDENTIFY ACTIVE PAGE
			const nowUrl = Astro.url.pathname
			const isActive = nowUrl === i.url || (i.url !== '/' && nowUrl.startsWith(i.url))
			const className = `flex items-center gap-2.5 font-light px-4 py-2 ${isActive ? 'bg-neutral-800 rounded-sm shadow-sm shadow-black/60 text-shadow-sm text-shadow-black text-neutral-50' : ''}`

			return (
				<a href={i.url} class={className}>
					<Icon name={i.icon} class="size-4" role="img" aria-label={i.label} title={i.label} />
					{i.label}
				</a>
			)
		})
	}
</div>
