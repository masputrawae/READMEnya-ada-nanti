---
const { title, img, ctaLink, ctaText = 'Read More' } = Astro.props
import Button from './Button.astro'
---

<figure
  class="max-w-full rounded-md border border-neutral-800 shadow shadow-black overflow-hidden lg:w-96"
>
  <picture class="block aspect-video overflow-hidden">
    <img src={img} alt={`Related Image ${title}`} class="w-full object-cover transition-transform hover:scale-125" />
  </picture>
  <figcaption class="px-3 py-6">
    <strong class="block text-2xl pb-1">{title}</strong>
    <blockquote class="font-light text-sm py-2.5">
      <slot />
    </blockquote>
    <footer class="mt-4">
      <Button class="text-xs" href={ctaLink} primary="true">
        {ctaText}
      </Button>
    </footer>
  </figcaption>
</figure>
