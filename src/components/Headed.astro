---
import { DEFAULT_PARAMS } from "../siteConfig"

const { site } = Astro
const { pathname } = Astro.url
const fullUrl = new URL(pathname, site).href

const { metaPage = {} } = Astro.props
const defaultMeta = DEFAULT_PARAMS.meta

const siteTitle = DEFAULT_PARAMS.siteTitle
const pageTitle = pathname === '/' ? siteTitle : `${siteTitle} | ${metaPage.pageTitle}`

const meta = {
  author: metaPage.author ?? defaultMeta.author,
  thumbnail: metaPage.thumbnail ?? defaultMeta.thumbnail,
  description: metaPage.description ?? defaultMeta.description,
  twitter: defaultMeta.twitter,
  keywords: (metaPage.keywords ?? defaultMeta.keywords).join(', '),
}

console.log(pathname)
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={fullUrl} />
  <meta name="theme-color" content="#0f172a" />

  <!-- START: FAVICONS -->
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicons/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicons/android-chrome-512x512.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png">
  <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
  <link rel="manifest" href="/favicons/site.webmanifest">
  <!-- START: END -->

  <!-- START: Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={meta.description} />
  <meta property="og:image" content={meta.thumbnail} />
  <meta property="og:url" content={fullUrl} />
  <meta property="og:type" content="website" />
  <!-- END: Open Graph (Facebook, LinkedIn, WhatsApp) -->

  <!-- START: Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={meta.description} />
  <meta name="twitter:image" content={meta.thumbnail} />
  <meta name="twitter:site" content={meta.twitter} />
  <!-- END: Twitter Card -->

  <title>{pageTitle}</title>
  <meta name="author" content={ meta.author } />
  <meta name="description" content={meta.description} />
  <meta name="keywords" content={meta.keywords} />

</head>
