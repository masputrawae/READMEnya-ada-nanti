---
import { Picture, Image } from 'astro:assets'
import Badge from './Badge.astro'
import Button from './Button.astro'
const { projects } = Astro.props
---

<article
  class="group flex flex-col gap-6 md:gap-8 md:border-b md:border-neutral-700 md:pb-16 md:grid md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2"
>
  <picture
    class="block overflow-hidden rounded-lg shadow-lg shadow-black aspect-video w-full max-w-2xl mx-auto xl:w-sm"
  >
    <Image
      src={projects.data.thumbnail}
      alt={projects.data.title}
      inferSize
      densities={[1, 1.5, 2, 3]}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </picture>

  <section class="flex flex-col gap-4 px-2 md:px-0 md:my-auto">
    <h2 class="text-3xl font-bold text-white">{projects.data.title}</h2>

    <div class="flex flex-wrap gap-2">
      {projects.data.tags.map((item: string) => <Badge>{item}</Badge>)}
    </div>

    <p class="text-neutral-300 leading-relaxed">{projects.data.description}</p>

    <Button
      onclick=`window.location.href='${projects.collection}/${projects.id}'`
      customClass="w-fit"
    >
      Read More
    </Button>
  </section>
</article>
