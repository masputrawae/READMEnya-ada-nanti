---
import { Icon } from 'astro-icon/components'
import { SOCIAL } from '../data/site'
import { MENU } from '../data/site'

import Menu from './Menu.astro'
import Brand from './Brand.astro'
---

<div
  id="sidebarOverlay"
  class="fixed size-full pointer-events-none z-40 opacity-0 bg-[rgba(0,0,0,0.4)] backdrop-blur-sm transition-all md:hidden"
>
</div>

<nav
  id="sidebar"
  class="grid grid-rows-[3.5rem_minmax(0,1fr)_auto] fixed top-0 z-50 h-dvh w-80 max-w-full border-r border-neutral-700 bg-neutral-800 px-4 py-1.5 transition-all invisible -translate-x-full"
>
  <div class="flex items-center justify-between h-14 w-full">
    <Brand />
    <button class="md:hidden" data-sidebar="sidebar">
      <Icon name="icon-x-mark" class="size-7" />
    </button>
  </div>

  <Menu menuParams={MENU} />
  <Menu menuParams={SOCIAL} />
</nav>

<script>
  const buttons = document.querySelectorAll('[data-sidebar]')
  const sidebarOverlay = document.getElementById('sidebarOverlay')

  function toggleSidebar(elm, overlay) {
    elm?.classList.toggle('-translate-x-full')
    elm?.classList.toggle('invisible')

    overlay?.classList.toggle('opacity-0')
    overlay?.classList.toggle('pointer-events-none')
  }

  sidebarOverlay?.addEventListener('click', () => {
    toggleSidebar(document.getElementById('sidebar'), sidebarOverlay)
  })

  buttons.forEach(btn => {
    const targetId = btn.getAttribute('data-sidebar')
    const sidebarEl = document.getElementById(`${targetId}`)

    btn.addEventListener('click', () => {
      toggleSidebar(sidebarEl, sidebarOverlay)
    })
  })
</script>
