---
import { Icon } from 'astro-icon/components'
const { menuParams } = Astro.props
---

<ul class="flex flex-col gap-1.5 px-2.5 py-3.5">
  {
    menuParams.map(item => {
      const isActive =
        Astro.url.pathname === item.url ||
        (item.url !== '/' && Astro.url.pathname.startsWith(item.url))

      const classLiActive = isActive
        ? 'shadow-sm text-white shadow-black bg-neutral-800 border border-neutral-600'
        : 'border-transparent'

      const classLinkActive = isActive ? 'text-white' : 'text-neutral-300'

      return (
        <li class={`p-2 rounded-md ${classLiActive}`}>
          <a
            href={item.url}
            class={`flex items-center gap-3 text-sm hover:text-white ${classLinkActive}`}
          >
            <Icon name={item.icon} class="size-4" />
            <span>{item.name}</span>
          </a>
        </li>
      )
    })
  }
</ul>
