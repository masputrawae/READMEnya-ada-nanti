---
import { Icon } from 'astro-icon/components'
const { menuParams } = Astro.props
---

<ul class="flex flex-col gap-1.5 p-2">
  {
    menuParams.map(item => {
      const isActive =
        Astro.url.pathname === item.url ||
        (item.url !== '/' && Astro.url.pathname.startsWith(item.url))

      const classLiActive = isActive
        ? 'border border-neutral-600 bg-neutral-800 text-white shadow-sm shadow-black'
        : 'border-transparent'

      const classLinkActive = isActive ? 'text-white' : 'text-neutral-300'

      return (
        <li class={`rounded-sm p-3 ${classLiActive}`}>
          <a
            href={item.url}
            class={`flex items-center gap-3 text-sm text-neutral-300 hover:text-white ${classLinkActive}`}
          >
            <Icon name={item.icon} class="size-4" />
            <span>{item.name}</span>
          </a>
        </li>
      )
    })
  }
</ul>
