---
import { Image, Picture } from 'astro:assets'
import Badge from './Badge.astro'
import Button from './Button.astro'
const { projects } = Astro.props
---

{
	projects.map((i) => (
		<article class="group mb-10 grid gap-3.5 overflow-hidden border-b border-neutral-700 pb-10 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 xl:gap-6">
			<picture class="m-auto aspect-video overflow-hidden rounded-md shadow-sm shadow-black/80 transition-all duration-500 group-hover:shadow-lg group-hover:shadow-black/50 xl:max-w-sm">
				<Image
					src={i.data.thumbnail}
					alt={i.data.title}
					width={600}
					height={400}
					format="webp"
					densities={[1, 1.5, 2, 3]}
					inferSize
					class="h-auto w-full transition-all duration-300 group-hover:scale-110"
				/>
			</picture>

			<section class="m-auto mt-3.5 flex max-w-lg flex-col gap-3.5">
				<nav class="flex items-center gap-1.5">
					{i.data.tags.map((tag) => (
						<Badge href={tag} title={tag} customClass="text-xs" />
					))}
				</nav>
				<strong class="text-xl text-neutral-50">{i.data.title}</strong>
				<p>{i.data.description}</p>
				<Button title="View Project" href={`/${i.id}/`} customClass="font-semibold text-lg" />
			</section>
		</article>
	))
}
