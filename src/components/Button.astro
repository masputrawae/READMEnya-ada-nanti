---
const { url, primary = false, label, customClass = '', ...rest } = Astro.props

const className = `px-5 py-2 cursor-pointer shadow-sm shadow-black no-underline border border-neutral-800 rounded-sm transition-all duration-300 hover:shadow-md hover:border-neutral-700 font-semibold ${primary ? 'bg-neutral-800 text-white ' : 'text-neutral-300 hover:text-white '} ${customClass}`
---

{
	!url ? (
		<button class={className} {...rest}>
			{!label ? <slot /> : label}
		</button>
	) : (
		<a href={url} class={className} {...rest}>
			{!label ? <slot /> : label}
		</a>
	)
}
