---
const { href, primary = false, customClass = '', title, ...rest } = Astro.props

const className = `inline-flex w-fit items-center px-4.5 py-1.5 rounded-sm shadow-xs shadow-black/80 text-shadow-sm text-shadow-black transition-all hover:bg-neutral-700/80 border border-neutral-700 hover:text-white`

const classPrimary = primary ? 'bg-neutral-800/80 text-white' : 'text-neutral-400 bg-neutral-900/50'
const classes = `${className} ${classPrimary} ${customClass}`
---

{
	!href ? (
		<button class={classes} {...rest}>
			{!title ? <slot /> : title}
		</button>
	) : (
		<a href={href} class={classes} {...rest}>
			{!title ? <slot /> : title}
		</a>
	)
}
