---
// components/head.astro

import { siteParams } from "../siteConfig";
const { meta = {} } = Astro.props

const { site } = Astro
const { pathname } = Astro.url
const fullUrl = new URL(pathname, site).href

const siteTitle = siteParams.title
const pageTitle = meta.title

const title = pathname === '/' ? siteTitle : `${siteTitle} | ${pageTitle}`
const author = siteParams.author
const twitter = meta.twitter
const thumbnail = meta.thumbnail ?? siteParams.thumbnail
const description = meta.description ?? siteParams.description
const keyword = (meta.keywords ?? siteParams.keyword).join(', ')
---
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#0f172a" />
  <link rel="canonical" href= />

  <!-- START: FAVICONS -->
  <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicons/android-chrome-192x192.png">
  <link rel="icon" type="image/png" sizes="512x512" href="/favicons/android-chrome-512x512.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png">
  <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
  <link rel="manifest" href="/favicons/site.webmanifest">
  <!-- START: END -->

  <!-- START: Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:title" content={ title } />
  <meta property="og:description" content={ description } />
  <meta property="og:image" content={ thumbnail } />
  <meta property="og:url" content={ fullUrl } />
  <meta property="og:type" content="website" />
  <!-- END: Open Graph (Facebook, LinkedIn, WhatsApp) -->

  <!-- START: Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ title } />
  <meta name="twitter:description" content={ description } />
  <meta name="twitter:image" content={ thumbnail } />
  <meta name="twitter:site" content={ twitter } />
  <!-- END: Twitter Card -->

  <title>{title}</title>
  <meta name="author" content={ author } />
  <meta name="description" content={ description } />
  <meta name="keywords" content={ keyword } />
</head>