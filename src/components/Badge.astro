---
interface Badge {
	href?: string | null
	className?: string
}

const { href = null, className = '', ...rest } = Astro.props as Badge

const classes = `badge ${className}`.trim()
---

{
	href ? (
		<a href={href} class={classes} {...rest}>
			<slot />
		</a>
	) : (
		<span class={classes} {...rest}>
			<slot />
		</span>
	)
}

<style itemscope>
	@reference "../styles/global.css";

	.badge {
		@apply inline-flex w-fit cursor-pointer items-center gap-1.5 rounded-full border border-neutral-800 bg-neutral-900 px-4 py-2 font-bold shadow-sm shadow-black transition-colors duration-300 text-shadow-black text-shadow-sm hover:bg-neutral-800 hover:text-white;
	}
</style>
