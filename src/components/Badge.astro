---
const { href, customClass, title, ...rest } = Astro.props
const className = `px-5 py-2 rounded-full shadow-sm shadow-black border border-neutral-700 font-semibold text-shadow-sm text-shadow-black bg-neutral-800 transition-all duration-300 cursor-pointer hover:bg-neutral-700/80 hover:text-neutral-50 ${customClass}`
---

{
	!href ? (
		<span class={className} {...rest}>
			{!title ? <slot /> : title}
		</span>
	) : (
		<a href={href} class={className} {...rest}>
			{!title ? <slot /> : title}
		</a>
	)
}
