---
import BaseLayout from '../../layouts/BaseLayout.astro';

import { getCollection } from 'astro:content';
const blog = await getCollection('blog')
const projects = await getCollection('projects')

const allItems = [...blog, ...projects]
const getPages = allItems.map(item => {
  return {
    ...item.data,
    slug: item.id,
    url: `/${item.collection}/${item.id}/`,
  }
})

const allTags = Array.from(
  new Set(
    allItems
      .map(item => item.data.tags || [])
      .flat()
  )
)

const tagCount = allItems.reduce((acc, item) => {
  const tags = item.data.tags || []
  tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1
  })
  return acc
}, {} as Record<string, number>)

---
<BaseLayout>
  <div class="tag-cloud">
    {Object.entries(tagCount).map(([tag, count]) => (
      <a
        href={`/tags/${tag}`}
        class="tag"
        style={`font-size: ${0.8 + count * 0.2}rem`}
      >
        {tag}
      </a>
    ))}
  </div>
</BaseLayout>
