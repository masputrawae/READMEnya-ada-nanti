---
import BaseLayout from '../assets/layouts/BaseLayout.astro'
import NavContent from '../assets/components/NavContent.astro'

import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths = (async () => {
	const docs = await getCollection('docs')

	return [
		...docs.map(entry => ({
			params: { history: `/History-In=${entry.id}/` },
			props: { entry }
		}))
	]
}) satisfies GetStaticPaths

const { entry } = Astro.props
---

<BaseLayout>
	<main class="max-w-full overflow-x-hidden">
		<NavContent entry={entry} />
		<article class="markdown">
      In history
		</article>
	</main>
</BaseLayout>
