---
import { getEntry, render } from 'astro:content'
import historyMap from '../data/historyMap.json'
import BaseLayout from '../assets/layouts/BaseLayout.astro'
import NavContent from '../assets/components/NavContent.astro'

export const prerender = false;

// Ambil slug dari params
let { slug } = Astro.params

const id = slug || 'home' // jika root, gunakan id 'home'

// Ambil entry dari koleksi 'docs' berdasarkan id
const doc = await getEntry('docs', id)

// Jika tidak ditemukan, redirect ke 404
if (!doc) {
	return Astro.redirect('/404')
}

// Render markdown menjadi komponen Content
const { Content } = await render(doc)

// History map
const filePath = doc.filePath ? `./${doc.filePath}` : ''
const history =
	doc.filePath && historyMap[doc.filePath as keyof typeof historyMap]
		? historyMap[doc.filePath as keyof typeof historyMap]
		: []

const q = Astro.url.searchParams.get("q") ?? undefined;
---

<BaseLayout>
	<div>
    <NavContent href={doc.id} q={q} />
    <h1>{doc.data.title}</h1>
		<article class="markdown">
      <Content />
    </article>
	</div>
</BaseLayout>
