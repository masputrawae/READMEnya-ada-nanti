---
import type { GetStaticPaths } from 'astro'
import { render, getCollection } from 'astro:content'
import historyMap from '../data/historyMap.json'
import BaseLayout from '../assets/layouts/BaseLayout.astro'
import ContentTab from '../assets/components/ContentTab.astro'

export const getStaticPaths = (async () => {
  const docs = await getCollection('docs')
  return [
    ...docs.map(doc => ({
      params: { slug: doc.id === 'home' ? '/' : doc.id },
      props: { doc },
    })),
  ]
}) satisfies GetStaticPaths

const { doc } = Astro.props
const { Content } = await render(doc)

// =================================== //
const filePath = doc.filePath ? `./${doc.filePath}` : '';
const history = doc.filePath && historyMap[doc.filePath as keyof typeof historyMap]
  ? historyMap[doc.filePath as keyof typeof historyMap]
  : [];
---

<BaseLayout>
  <ContentTab>
    <article slot="readTab">
      <h1>Discussion: {doc.data.title}</h1>
      <Content />
    </article>
    <article slot="discussionTab">
      <h1>Discussion: {doc.data.title}</h1>
    </article>
    <article slot="historyTab">
      <h1>history: {doc.data.title}</h1>
    </article>
    <article slot="searchTab">
      <h1>Search: {doc.data.title}</h1>
    </article>
  </ContentTab>
</BaseLayout>