---
import { getContents } from '../utils/getContent.js'

import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectsComponent from '../components/ProjectsComponent.astro'

const projects = await getContents('all', 'projects')
---

<BaseLayout>
	<header
		class="prose prose-invert prose-neutral max-w-none text-[14px] leading-normal font-light md:text-[15px] lg:text-[16px]"
	>
		<h1 class="font-light">Proyek-proyek Saya</h1>

		<em class="not-italic">Tempat saya mencatat perjalanan belajar sebagai programmer otodidak.</em>
		<p>
			Berikut adalah beberapa proyek kecil yang saya buat selama proses belajar pemrograman secara
			otodidak. Tidak ada yang sempurna, tapi setiap baris kodenya adalah bagian dari perjalanan
			saya memahami dunia teknologi. Saya membuat proyek-proyek ini untuk bersenang-senang,
			bereksperimen, dan mengasah kemampuan. Kadang iseng, kadang serius—tapi semuanya adalah
			langkah kecil yang berarti.
		</p>

		<p>
			Catatan: Semua proyek di sini masih dalam tahap belajar. Kalau ada yang menarik atau ingin
			memberi masukan, saya akan sangat menghargainya!
		</p>
	</header>

	<div class="mt-20 text-[14px] md:text-[15px] lg:text-[16px]">
		<h2 class="text-3xl font-light text-neutral-50">Featured Projects</h2>
		<p>Karya yang menurutku terbaik</p>
		<div class="mt-16">
			<ProjectsComponent projects={projects} />
		</div>
	</div>
</BaseLayout>
