---
import Base from '../layouts/Base.astro'
import Prose from '../components/Prose.astro'
import FeaturedNotes from '../components/FeaturedNotes.astro'

import { getCollection } from 'astro:content'

const getAllPosts = await getCollection('vaults')
const allProjects = getAllPosts
	.filter((i) => i.data.type === 'Projects')
	.sort((a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime())
---

<Base>
	<Prose>
		<header class="mx-auto mt-40 max-w-5xl px-3.5">
			<h1>Proyek-proyek Saya</h1>

			<p>
				Berikut adalah beberapa proyek kecil yang saya buat selama proses belajar pemrograman secara
				otodidak. Tidak ada yang sempurna, tapi setiap baris kodenya adalah bagian dari perjalanan
				saya memahami dunia teknologi. Saya membuat proyek-proyek ini untuk bersenang-senang,
				bereksperimen, dan mengasah kemampuan. Kadang iseng, kadang serius—tapi semuanya adalah
				langkah kecil yang berarti.
			</p>

			<p>
				<strong>Catatan:</strong> Semua proyek di sini masih dalam tahap belajar. Kalau ada yang menarik
				atau ingin memberi masukan, saya akan sangat menghargainya!
			</p>
		</header>

		<main class="mx-auto mt-20 max-w-5xl px-3.5">
			<FeaturedNotes items={allProjects} type="projects" heading="All Projects" withClock={false} />
		</main>
	</Prose>
</Base>
