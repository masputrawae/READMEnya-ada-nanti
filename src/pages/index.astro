---
import BaseLayouts from "../layouts/BaseLayouts.astro";
import Button from "../components/Button.astro";
import ProjectFeatured from '../components/ProjectFeatured.astro'
import { siteParams } from "../siteConfig";

import { getCollection } from "astro:content";

const project = await getCollection('projects')
const filtered = project.sort((a, b) => {
  const dateA = new Date(a.data.date).getTime()
  const dateB = new Date(b.data.date).getTime()
  return dateB - dateA
})

const lastProjects = filtered.slice(0, 2)
---
<BaseLayouts>
  <header class="pt-24 pb-16 max-w-5xl mx-auto px-6 min-h-[80dvh] flex flex-col justify-center">
    <div class="mb-8">
      <h1 class="text-5xl font-bold mb-3 text-white">👋 Halo, Selamat Datang!</h1>
      <em class="text-neutral-400">Tempat saya mencatat perjalanan belajar sebagai programmer otodidak.</em>
    </div>
    
    <div class="prose prose-invert max-w-none">
      <p class="text-neutral-300 leading-relaxed">
        Blog ini berisi catatan belajar saya dalam bidang <strong>JavaScript, Python, dan teknologi web</strong>. Saya juga menulis hal-hal yang saya pelajari seputar <strong>matematika dasar</strong> dan <strong>bahasa Inggris</strong>.
      </p>
      <p class="text-neutral-300 leading-relaxed mt-6">
        Semua catatan ditulis dengan gaya santai dan apa adanya. Kalau kamu juga belajar hal yang sama, semoga bisa jadi teman belajar yang menyenangkan.
      </p>
    </div>
    
    <nav class="flex flex-wrap items-center gap-3 mt-8">
      {
        siteParams.cta.map(item => (
          <Button 
            href={item.url} 
            primary={item.primary} 
            customClass="text-lg"
          >
            {item.label}
          </Button>
        ))
      }
    </nav>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-12">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-2">Last Projects</h2>
      <p class="text-neutral-400">Yang terbaru dari karya saya</p>
    </div>
    
    <div class="grid gap-8 md:gap-12">
      {
        lastProjects.map(item => (
          <ProjectFeatured projects={{...item}} />
        ))
      }
    </div>
  </main>
</BaseLayouts>