---
import BaseLayout from '../assets/layouts/BaseLayout.astro'
import NavContent from '../assets/components/NavContent.astro'

import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import Giscus from '../assets/components/Giscus.astro'

export const getStaticPaths = (async () => {
	const docs = await getCollection('docs')

	return [
		...docs.map(doc => ({
			params: { discussion: `/Discussion-In/${doc.id}` },
			props: { doc }
		}))
	]
}) satisfies GetStaticPaths

const { doc } = Astro.props
---

<BaseLayout>
	<main class="max-w-full overflow-x-hidden">
		<div class="px-2 lg:px-4 xl:px-8">
			<NavContent entry={doc} activeIn="discussionPage" />
			<aside class="markdown min-h-dvh border border-zinc-800 px-2 lg:px-4 xl:px-8">
				<h1>Talk In: {doc.data.title}</h1>
				<Giscus />
			</aside>
		</div>
	</main>
</BaseLayout>
