---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

// 🚀 Fungsi wajib untuk halaman dinamis
export async function getStaticPaths() {
  const project = await getCollection('projects');
  const blog = await getCollection('blog');

  const combined = [...project, ...blog];

  const rawCategories = combined.flatMap(item => item.data.categories || []);
  const uniqueCategories = [...new Set(rawCategories)];

  const paths = uniqueCategories.map(category => {
    const slug = category
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/_+/g, '-');
    return { params: { slug } };
  });

  return paths;
}

// --- Halaman utama ---
const { slug } = Astro.params;

const project = await getCollection('projects');
const blog = await getCollection('blog');

const combined = [...project, ...blog];

const filtered = combined.filter(item => {
  const categories = item.data.categories || [];
  return categories.some(tag =>
    tag.toLowerCase().replace(/\s+/g, '-').replace(/_+/g, '-') === slug
  );
});

const meta = {
  pageTitle: `Categories: ${slug.replace(/-/g, ' ').toUpperCase()}`,
  description: `Semua post dengan category ${slug}`,
};
---

<BaseLayout metaPage={meta}>
  <h1 class="text-2xl font-bold mb-4">Category: {slug.replace(/-/g, ' ').toUpperCase()}</h1>

  {filtered.length === 0 ? (
    <p>Tidak ada post dengan tag ini.</p>
  ) : (
    <ul class="space-y-2">
      {
        filtered.map(item => (
          <li>
            <a href={`/${item.collection}/${item.id}/`} class="text-blue-600 hover:underline">
              {item.data.title}
            </a>
          </li>
        ))
      }
    </ul>
  )}
</BaseLayout>
