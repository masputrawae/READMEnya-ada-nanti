---
import { getEntry } from "astro:content"
import BaseLayout from "../../assets/layouts/BaseLayout.astro"

let { source } = Astro.params

const id = source || 'home'

const doc = await getEntry('docs', id)

if (!doc) {
	return Astro.redirect('/404')
}

const rawFilePath = doc.filePath ? `/${doc.filePath}` : ''
const markdownFiles = import.meta.glob('/src/content/docs/**/*.md', {
	query: '?raw',
	import: 'default'
})

const loadRaw = markdownFiles[rawFilePath]
const rawMarkdown = loadRaw ? await loadRaw() : null

---

<BaseLayout>
  <article class="markdown">
		<pre>{rawMarkdown}</pre>
  </article>
</BaseLayout>