---
import type { GetStaticPaths } from 'astro'
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { execSync } from 'child_process'

export const getStaticPaths = (async () => {
  const docs = await getCollection('docs')
  const paths: Array<{
    params: { dif: string },
    props: { docId: string, filePath: string, commitHash: string, title: string }
  }> = []

  for (const doc of docs) {
    // Dapatkan semua versi commit untuk file ini
    const commits = execSync(`git log --pretty=format:"%h" -- "${doc.filePath}"`)
      .toString()
      .trim()
      .split('\n')

    // Generate path untuk setiap kombinasi doc + commit
    commits.forEach((commitHash: string) => {
      paths.push({
        params: { 
          dif: `/${doc.id}/${commitHash}/` 
        },
        props: {
          docId: doc.id,
          filePath: doc.filePath ?? '',
          commitHash,
          title: doc.data.title
        }
      })
    })
  }

  return paths
}) satisfies GetStaticPaths

const { docId, filePath, commitHash, title } = Astro.props


// Ambil konten file untuk commit spesifik
const fileContent = execSync(`git show ${commitHash}:${filePath}`).toString()

// Dapatkan info commit lengkap
const commitInfo = execSync(`git show -s --format="%ci|%an|%s" ${commitHash}`)
  .toString()
  .trim()
  .split('|')
---


<Layout href={docId} activeLink="history">
  <article>
    <h1>{title} @{commitHash.slice(0, 7)}</h1>
    
    <div class="commit-info">
      <p>Author: {commitInfo[1]}</p>
      <p>Date: {new Date(commitInfo[0]).toLocaleString()}</p>
      <p>Message: {commitInfo[2]}</p>
    </div>

    <div class="file-content">
      <pre>{fileContent}</pre>
    </div>

    <nav class="history-nav">
      <!-- Tambahkan link ke versi lain jika diperlukan -->
      <a href={`/History/${docId}`}>Back to version list</a>
    </nav>
  </article>
</Layout>

<style>
  .commit-info {
    background: var(--theme-bg-alt);
    padding: 1rem;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
  }
  
  .file-content {
    background: var(--theme-code-bg);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }
</style>